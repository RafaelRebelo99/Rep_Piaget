# =========================================================================
# INSTRUÇÕES DE CONFIGURAÇÃO DAS VARIÁVEIS DE AMBIENTE
# =========================================================================
# 1. Renomeia este ficheiro para .env.local para uso local.
# 2. SUPABASE: Consulta o Dashboard do Supabase (Project Settings -> API).
# 3. RESEND: Cria uma conta em resend.com e gera uma chave em 'API Keys'.
# 4. Preenche os valores abaixo com as chaves reais obtidas.
#
# ⚠️ ATENÇÃO: NUNCA faças commit do ficheiro .env.local! 
# =========================================================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# RESEND
RESEND_API_KEY=
